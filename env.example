# ============================================================
#  G H O S T — API Keys Template
#  Copy this file, rename it to .env, and fill in your keys.
#  Get all keys for FREE from the links below.
# ============================================================

# 1. Groq — console.groq.com → API Keys → Create Key
GROQ_API_KEY=your_groq_key_here

# 2. Cerebras — inference.cerebras.ai → API Keys
CEREBRAS_API_KEY=your_cerebras_key_here

# 3. SambaNova — cloud.sambanova.ai → API Key
SAMBANOVA_API_KEY=your_sambanova_key_here

# 4. OpenRouter — openrouter.ai → Keys
OPENROUTER_API_KEY=your_openrouter_key_here

# 5. Cohere — dashboard.cohere.com → API Keys
COHERE_API_KEY=your_cohere_key_here

# 6. Mistral — console.mistral.ai → API Keys
MISTRAL_API_KEY=your_mistral_key_here

# 7. Gemini — aistudio.google.com (used for vision/camera)
GEMINI_API_KEY_1=your_gemini_key_here

# Other APIs
WEATHER_API_KEY=your_openweather_key_here     # openweathermap.org
YOUTUBE_API_KEY=your_youtube_key_here         # console.cloud.google.com
NEWS_API_KEY=your_newsapi_key_here            # newsapi.org
